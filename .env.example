# Supabase Database Connection (Pooled for Prisma)
DATABASE_URL="postgres://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true"

# Supabase Project URL
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"

# Supabase Anon Key (public, safe to expose)
SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Supabase JWT Secret (keep secret)
SUPABASE_JWT_SECRET="your_jwt_secret_here"

# Supabase Service Role Key (keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# Next.js Public Variables
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxx"
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"

# PostgreSQL SSL mode for self-signed certificates only.
# Use PGSSLMODE=no-verify when connecting to a DB with an unsupported or self-signed TLS cert.
PGSSLMODE="no-verify"

# Application Secrets
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
